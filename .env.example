# ---- MongoDB ----
# Local: mongodb://localhost:27017/mimic
# Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/mimic?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/mimic

# ---- NextAuth ----
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public origin the Socket.IO client connects to (usually same as APP_URL)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

PORT=3000
