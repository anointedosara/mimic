# ---- MongoDB ----
# Local: mongodb://localhost:27017/mimic
# Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/mimic?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/mimic

# ---- NextAuth ----
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Ably (real-time transport) ----
# Server-only. The browser gets a short-lived scoped token from /api/ably/token.
# Get a key at https://ably.com (Root key is fine — token scoping does the rest).
ABLY_API_KEY=appId.keyId:keySecret

# ---- Upstash QStash (serverless phase timers) ----
# Prod only: schedules the callback that auto-advances game phases. Locally an
# in-process setTimeout is used instead (QStash can't reach localhost).
# Get these at https://console.upstash.com/qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ---- Voice (WebRTC) TURN relay ----
# STUN alone only connects peers reachable via their public address. Players on
# different networks behind strict/symmetric NATs need a TURN relay to hear each
# other. NOTE: WebRTC mic capture also requires HTTPS (or localhost) — serving
# over a plain http:// LAN IP blocks voice regardless of TURN.
#
# A managed provider (below) is fetched server-side per join. Only one is used;
# they're tried in order: Cloudflare, then Metered, then static.
#
# Option 1: Metered — dashboard → TURN Server. Copy the app name + API key.
#   METERED_APP_NAME = your app subdomain, e.g. "myapp" (or "myapp.metered.live")
#   METERED_API_KEY  = the API key shown on that page
METERED_APP_NAME=
METERED_API_KEY=
#
# Option 2: Cloudflare Realtime TURN — dashboard → Realtime → TURN → create app.
#   CLOUDFLARE_TURN_KEY_ID   = the "Turn Token ID"
#   CLOUDFLARE_TURN_API_TOKEN= the "API Token"
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
#
# Option 3: static TURN (self-hosted coturn / copy-paste creds). Set all three.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
# Optional: override the default Google STUN servers (comma-separated).
STUN_URLS=
